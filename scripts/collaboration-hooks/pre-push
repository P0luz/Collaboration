#!/bin/bash
# Collaboration pre-push hook
# 是什么:推送前拦截器,确保房间内没有未解决的 waiting 状态锁。
# 做什么:查询 /api/collaboration/status,若存在 waiting 锁则 block push。
# 不做什么:Collaboration 未配置(无 ROOM)时直接放行。
# 依赖环境变量:COLLABORATION_URL(默认 http://localhost:8080)、COLLABORATION_ROOM
# 依赖外部命令:curl、jq

COLLABORATION_URL="${COLLABORATION_URL:-http://localhost:8080}"
COLLABORATION_ROOM="${COLLABORATION_ROOM:-}"

if [ -z "$COLLABORATION_ROOM" ]; then
    exit 0
fi

RESPONSE=$(curl -s "$COLLABORATION_URL/api/collaboration/status/$COLLABORATION_ROOM")
if [ -z "$RESPONSE" ]; then
    echo "[Collaboration] 无法连接 $COLLABORATION_URL,push 暂停。请确认服务在运行。"
    exit 1
fi

# status 端点显式返回 waiting_locks;字段缺失时按空数组处理,兼容旧服务。
WAITING=$(echo "$RESPONSE" | jq '(.waiting_locks // []) | length')

if [ "$WAITING" != "null" ] && [ "$WAITING" -gt 0 ] 2>/dev/null; then
    echo ""
    echo "[Collaboration] push 被阻止。"
    echo "存在 $WAITING 个未解决的 waiting 状态。"
    echo "请先解决所有冲突再 push。"
    echo ""
    exit 1
fi

exit 0
