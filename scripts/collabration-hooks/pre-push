#!/bin/bash
# Collabration pre-push hook
# 是什么:推送前拦截器,确保房间内没有未解决的 waiting 状态锁。
# 做什么:查询 /api/collabration/status,若存在 waiting 锁则 block push。
# 不做什么:Collabration 未配置(无 ROOM)时直接放行。
# 依赖环境变量:COLLABRATION_URL(默认 http://localhost:8080)、COLLABRATION_ROOM
# 依赖外部命令:curl、jq

COLLABRATION_URL="${COLLABRATION_URL:-http://localhost:8080}"
COLLABRATION_ROOM="${COLLABRATION_ROOM:-}"

if [ -z "$COLLABRATION_ROOM" ]; then
    exit 0
fi

RESPONSE=$(curl -s "$COLLABRATION_URL/api/collabration/status/$COLLABRATION_ROOM")
if [ -z "$RESPONSE" ]; then
    echo "[Collabration] 无法连接 $COLLABRATION_URL,push 暂停。请确认服务在运行。"
    exit 1
fi

# status 端点的 active_locks 只含 active;waiting 锁需单独从全量状态判断。
# 这里通过 /status 暂只反映 active;waiting 计数由专门字段提供时再扩展。
# 当前实现:检查 active_locks 中是否混入 waiting(防御式;正常不会)。
WAITING=$(echo "$RESPONSE" | jq '[.active_locks[]? | select(.status == "waiting")] | length')

if [ "$WAITING" != "null" ] && [ "$WAITING" -gt 0 ] 2>/dev/null; then
    echo ""
    echo "[Collabration] push 被阻止。"
    echo "存在 $WAITING 个未解决的 waiting 状态。"
    echo "请先解决所有冲突再 push。"
    echo ""
    exit 1
fi

exit 0
